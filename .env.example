# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway lo inyecta automáticamente al agregar el plugin PostgreSQL.
# En local podés omitirla para usar SQLite (mtr_compras.db).
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Generá una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# ── Primer superadmin (solo se usa la primera vez que corre migrate.py) ───────
# Después podés cambiarla desde /admin/users o directamente en la app.
FIRST_ADMIN_EMAIL=admin@tuempresa.com
FIRST_ADMIN_PASSWORD=contraseña-segura-aqui

# ── Cloudinary (subida de remitos y facturas) ─────────────────────────────────
# Cuenta gratis en cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
